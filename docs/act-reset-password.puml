@startuml

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

skinparam activity {
    BackgroundColor #F5F5F5
    BorderColor #444444
    FontColor #222222
    DiamondBackgroundColor #E8E8E8
    DiamondBorderColor #444444
    ArrowColor #444444
}

skinparam partition {
    BackgroundColor #FAFAFA
    BorderColor #999999
    FontColor #333333
    FontStyle bold
}

skinparam swimlane {
    BorderColor #666666
    TitleFontSize 11
    TitleFontStyle bold
}

title <size:13>Diagramme d'activité — Réinitialiser le mot de passe</size>

|#FAFAFA| Candidat |
start
:Cliquer « Mot de passe oublié ? »;
:Saisir l'email et soumettre;

|#F2F2F2| LWC forgetMotDePasse |
:Appeler generateResetToken();

|#EBEBEB| Apex PasswordResetController |
:Générer token 256 bits (CSPRNG);
:Calculer hash SHA-256\n(token clair jamais persisté);
:Insérer Password_Reset_Token__c\n(hash, expiration 24h, attempts=0);
:Envoyer email avec lien + token;
:Journaliser Security_Audit_Log__c\n(TOKEN_CREATED, INFO);

|#F2F2F2| LWC forgetMotDePasse |
#DDDDDD:« Un email a été envoyé »\n(même réponse si inconnu);

|#FAFAFA| Candidat |
:Cliquer sur le lien dans l'email;

|#F2F2F2| LWC setPassword |
:Appeler validateToken(token);

|#EBEBEB| Apex PasswordResetController |
:Calculer hash SHA-256 du token reçu;
:Rechercher Password_Reset_Token__c;

if (Token trouvé ?) then (oui)
    if (Non expiré ET non utilisé ?) then (oui)
        if (Attempts ≤ 3 ?) then (oui)
            :Incrémenter Attempts__c;
        else (non)
            :Invalider token (Is_Used=true);
            :Journaliser (TOKEN_BLOCKED, CRITICAL);
            #DDDDDD:« Lien invalide ou expiré »;
            stop
        endif
    else (non)
        :Journaliser (TOKEN_EXPIRED, WARNING);
        #DDDDDD:« Lien invalide ou expiré »;
        stop
    endif
else (non)
    :Journaliser (TOKEN_FAILED, WARNING);
    #DDDDDD:« Lien invalide ou expiré »;
    stop
endif

|#F2F2F2| LWC setPassword |
:Afficher formulaire\n(nouveau mot de passe + confirmation);

|#FAFAFA| Candidat |
:Saisir le nouveau mot de passe;

|#EBEBEB| Apex PasswordResetController |
if (Validation OWASP ?\n(≥8 chars, maj, min, chiffre, spécial)) then (oui)
    :System.setPassword(userId, newPwd);
    :Marquer token utilisé (Is_Used=true);
    :Journaliser (PASSWORD_SET, INFO);

    |#FAFAFA| Candidat |
    #DDDDDD:« Mot de passe mis à jour !\nVous pouvez vous connecter. »;
    stop
else (non)
    |#F2F2F2| LWC setPassword |
    :Afficher critères non respectés;
    |#FAFAFA| Candidat |
    :Ressaisir le mot de passe;
    stop
endif

@enduml
