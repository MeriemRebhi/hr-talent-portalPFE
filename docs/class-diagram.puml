@startuml

skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classFontSize 10
skinparam defaultFontSize 10
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 50
skinparam classBackgroundColor white
skinparam classHeaderBackgroundColor white
skinparam backgroundColor white
hide circle

' ══════════════════════════════════════════
'  OBJETS STANDARD
' ══════════════════════════════════════════

class Lead <<Standard Object>> {
    Id : ID
    FirstName : String
    LastName : String
    Email : Email
    Status : Picklist
    Rating : Picklist
    IsConverted : Boolean
    Score_Matching__c : Number
    AI_Recommendation__c : LongText
    AI_Points_Forts__c : LongText
    AI_Points_Faibles__c : LongText
    Adresse_exacte__c : Text
    Code_postale__c : Text
}

class Account <<Standard Object>> {
    Id : ID
    Name : String
}

class Contact <<Standard Object>> {
    Id : ID
    FirstName : String
    LastName : String
    Email : Email
    AccountId : ID
}

class User <<Standard Object>> {
    Id : ID
    Username : String
    Email : Email
    ProfileId : ID
    ContactId : ID
    IsActive : Boolean
}

class Opportunity <<Standard Object>> {
    Id : ID
    Name : String
    StageName : Picklist
    CloseDate : Date
    RecordTypeId : ID
    AccountId : ID
    Is_Candidature__c : Boolean
    Description_Poste__c : LongText
    Departement__c : Picklist
    Localisation__c : Text
    Type_de_Contrat__c : Picklist
    Salaire_Propos__c : Currency
    Score_Matching__c : Number
    Gaming_Test_Score__c : Number
    Gaming_Test_DateTime__c : DateTime
    Gaming_Test_Duration__c : Number
    Gaming_Meet_Link__c : Text
    Gaming_Test_Status__c : Picklist
    Manager_Validated_Score__c : Number
}

class ContentVersion <<Standard Object>> {
    Id : ID
    Title : String
    VersionData : Blob
    ContentDocumentId : ID
}

class ContentDocumentLink <<Junction>> {
    ContentDocumentId : ID
    LinkedEntityId : ID
}

' ══════════════════════════════════════════
'  OBJETS CUSTOM
' ══════════════════════════════════════════

class Technical_Interview__c <<Custom Object>> {
    Id : ID
    Opportunity__c : Lookup(Opportunity)
    Interview_DateTime__c : DateTime
    Duration__c : Number
    Meet_Link__c : Text
    Score__c : Number
    Status__c : Picklist
    Composite_Score__c : Number
    Manager_Notes__c : LongText
    Reschedule_Requested__c : Boolean
}

class Architecture_Interview__c <<Custom Object>> {
    Id : ID
    Opportunity__c : Lookup(Opportunity)
    Interview_DateTime__c : DateTime
    Duration__c : Number
    Meet_Link__c : Text
    Jitsi_Room__c : Text
    Score__c : Number
    Status__c : Picklist
    Transcription__c : LongText
    AI_Feedback__c : LongText
    Audio_ContentVersion_Id__c : Text
    Manager_Notes__c : LongText
    Reschedule_Requested__c : Boolean
}

class Gaming_Question__c <<Custom Object>> {
    Id : ID
    Job_Posting__c : Lookup(Opportunity)
    Question_Text__c : LongText
    Question_Type__c : Picklist
    Difficulty__c : Picklist
    Correct_Answer__c : Text
    Option_A__c : Text
    Option_B__c : Text
    Option_C__c : Text
    Option_D__c : Text
    Option_E__c : Text
    Time_Limit__c : Number
}

class Technical_Question__c <<Custom Object>> {
    Id : ID
    Job_Posting__c : Lookup(Opportunity)
    Opp_Reference__c : Lookup(Opportunity)
    Problem_Text__c : LongText
    Problem_Type__c : Picklist
    Difficulty__c : Picklist
    Time_Limit__c : Number
    Expected_Solution__c : LongText
    Evaluation_Criteria__c : LongText
    Candidate_Answer__c : LongText
    AI_Score__c : Number
    AI_Feedback__c : LongText
}

class Password_Reset_Token__c <<Custom Object>> {
    Id : ID
    User__c : Lookup(User)
    Token_Hash__c : Text(64)
    Email__c : Text
    Expiration__c : DateTime
    Attempts__c : Number
    Is_Used__c : Boolean
}

class Security_Audit_Log__c <<Custom Object>> {
    Id : ID
    Action__c : Text
    Email__c : Text
    Severity__c : Text
    Timestamp__c : DateTime
    Details__c : LongText
}

class QrLogin__c <<Custom Object>> {
    Id : ID
    Token__c : Text
    Is_Validated__c : Boolean
    Expiration__c : DateTime
}

class RH_Decision__c <<Custom Object>> {
    Id : ID
    Opportunity__c : Lookup(Opportunity)
    Responsable_RH__c : Lookup(User)
    Decision__c : Picklist
    Date_Decision__c : DateTime
    Motif_Refus__c : LongText
    Commentaire__c : LongText
}

class Contract <<Standard Object>> {
    Id : ID
    AccountId : ID
    Status : Picklist
    StartDate : Date
    ContractTerm : Number
    Description : LongText
}

class dfsle__Envelope__c <<DocuSign>> {
    Id : ID
    dfsle__SourceId__c : Lookup(Contract)
    dfsle__Status__c : Picklist
    dfsle__SentDateTime__c : DateTime
    dfsle__CompletedDateTime__c : DateTime
    dfsle__EmailSubject__c : Text
}

class dfsle__EnvelopeStatus__c <<DocuSign>> {
    Id : ID
    dfsle__Envelope__c : Lookup(Envelope)
    dfsle__Signer__c : Text
    dfsle__Status__c : Picklist
    dfsle__SignedDateTime__c : DateTime
}

class RecordType <<Standard Object>> {
    Id : ID
    DeveloperName : String
    ..
    Job_Posting
    Application
}

