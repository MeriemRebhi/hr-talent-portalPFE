@startuml

skinparam monochrome true
skinparam shadowing false
skinparam defaultFontSize 10
skinparam sequenceMessageAlign center
skinparam backgroundColor white
skinparam sequenceLifeLineBorderColor black
skinparam sequenceParticipantBackgroundColor white

title Diagramme de séquence — Réinitialiser le mot de passe

actor "Candidat" as C
participant "forgetMotDePasse\n(LWC)" as FMP
participant "setPassword\n(LWC)" as SP
participant "PasswordResetController\n(Apex)" as PRC
database "Salesforce\n(Password_Reset_Token__c,\nSecurity_Audit_Log__c)" as DB
participant "Email Service" as EM

== Phase 1 : Demande de réinitialisation ==

C -> FMP : Cliquer « Mot de passe oublié ? »
activate FMP
FMP --> C : Afficher le formulaire\n(saisie email)

C -> FMP : Saisir l'email et soumettre
FMP -> PRC : generateResetToken(userId, email)
activate PRC

PRC -> PRC : Générer token 256 bits\nvia Crypto.getRandomInteger()\n(CSPRNG)
PRC -> PRC : Calculer hash SHA-256\n(le token en clair n'est\njamais persisté)

PRC -> DB : INSERT Password_Reset_Token__c\n(Token_Hash__c, Email__c,\nExpiration__c = now + 24h,\nIs_Used__c = false,\nAttempts__c = 0)

PRC -> EM : Envoyer email avec lien\ncontenant le token en clair
EM --> C : Email reçu

PRC -> DB : INSERT Security_Audit_Log__c\n(Action='PasswordResetRequested',\nSeverity='INFO')

PRC --> FMP : OK
deactivate PRC

FMP --> C : « Un email a été envoyé »\n(même message si email inconnu\n— anti-énumération)
deactivate FMP

== Phase 2 : Validation et changement ==

C -> SP : Cliquer sur le lien\ndans l'email
activate SP
SP -> PRC : validateToken(token)
activate PRC

PRC -> PRC : Calculer hash SHA-256\ndu token reçu
PRC -> DB : SELECT FROM\nPassword_Reset_Token__c\nWHERE Token_Hash__c = :hash

alt Token valide
    PRC -> PRC : Vérifier :\n✓ Expiration > now\n✓ Is_Used__c = false\n✓ Attempts__c ≤ 3
    PRC -> DB : UPDATE Attempts__c += 1
    PRC --> SP : email (token valide)
    deactivate PRC

    SP --> C : Afficher le formulaire\n(nouveau mot de passe\n+ confirmation)

    C -> SP : Saisir nouveau mot de passe
    SP -> PRC : setPasswordWithToken(token, newPassword)
    activate PRC

    PRC -> PRC : validatePasswordStrength()\n(8+ chars, majuscule,\nminuscule, chiffre,\ncaractère spécial)

    alt Mot de passe robuste
        PRC -> DB : System.setPassword(userId, newPwd)
        PRC -> DB : UPDATE Password_Reset_Token__c\n(Is_Used__c = true)
        PRC -> DB : INSERT Security_Audit_Log__c\n(Action='PasswordResetSuccess',\nSeverity='INFO')
        PRC --> SP : OK
        SP --> C : « Mot de passe mis à jour !\nVous pouvez vous connecter. »
    else Mot de passe faible
        PRC --> SP : Erreur : critères non satisfaits
        SP --> C : Afficher les critères\nnon respectés
    end
    deactivate PRC

else Token invalide / expiré / utilisé
    PRC -> DB : INSERT Security_Audit_Log__c\n(Action='InvalidToken',\nSeverity='WARNING')
    PRC --> SP : AuraHandledException\n« Lien invalide ou expiré »
    deactivate PRC
    SP --> C : Message générique\n(anti-énumération)

else Tentatives > 3
    PRC -> DB : UPDATE Is_Used__c = true\n(invalidation forcée)
    PRC -> DB : INSERT Security_Audit_Log__c\n(Action='TokenBlocked',\nSeverity='CRITICAL')
    PRC --> SP : AuraHandledException\n« Lien invalide ou expiré »
    deactivate PRC
    SP --> C : Message générique
end

deactivate SP

@enduml
