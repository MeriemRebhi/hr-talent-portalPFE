@startuml
title Diagramme de cas d'utilisation — HR Talent Portal

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle stickman
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontSize 12
skinparam linetype ortho

actor "Visiteur" as V
actor "Candidat" as C
actor "Recruteur" as R
actor "Manager" as M
actor "Responsable RH" as RRH
actor "Système IA" as IA <<System>>

V <|-- C

rectangle "HR Talent Portal — Salesforce Experience Cloud" {

    usecase "S'authentifier" as UC_AUTH
    usecase "S'inscrire" as UC_REGISTER

    package "Espace public" {
        usecase "Consulter les offres" as UC_OFFRES
        usecase "Déposer candidature" as UC_DEPOSER
    }

    package "Espace candidat" {
        usecase "Test Gaming" as UC_GAMING
        usecase "Entretien Technique" as UC_TECH
        usecase "Entretien Architecture\n(Jitsi)" as UC_ARCH
        usecase "Demander un report" as UC_REPORT
        usecase "Suivre l'avancement" as UC_SUIVI
        usecase "Gérer profil / CV" as UC_PROFIL
        usecase "Chatbot NLP" as UC_CHAT
    }

    package "Espace recruteur" {
        usecase "Gérer les offres" as UC_PUBLIER
        usecase "Planifier Gaming" as UC_PLAN_GAMING
        usecase "Planifier Technique" as UC_PLAN_TECH
        usecase "Planifier Architecture" as UC_PLAN_ARCH
        usecase "Replanifier" as UC_REPLAN
        usecase "Changer le stage" as UC_STAGE
    }

    package "Espace manager" {
        usecase "Consulter résultats" as UC_DETAIL
        usecase "Valider / Ajuster score" as UC_VALIDER
        usecase "Décision finale" as UC_DECISION
    }

    package "Espace RH" {
        usecase "Dashboards & KPIs" as UC_KPI
        usecase "Pipeline recrutement" as UC_PIPELINE
        usecase "Onboarding" as UC_ONBOARD
    }

    package "Automatisations IA" {
        usecase "Scorer CV (LLaMA)" as UC_SCORER
        usecase "Score Composite" as UC_COMPOSITE
        usecase "Évaluer réponses\ntechniques" as UC_EVALREPONSE
        usecase "Transcrire audio\n(Whisper)" as UC_WHISPER
        usecase "Analyser architecture\n(LLaMA)" as UC_ARCH_EVAL
        usecase "Convertir Lead" as UC_CONVERT
        usecase "Notifications email" as UC_EMAIL
    }
}

V -- UC_OFFRES
V -- UC_DEPOSER
V -- UC_REGISTER

C -- UC_GAMING
C -- UC_TECH
C -- UC_ARCH
C -- UC_REPORT
C -- UC_SUIVI
C -- UC_PROFIL
C -- UC_CHAT

R -- UC_PUBLIER
R -- UC_PLAN_GAMING
R -- UC_PLAN_TECH
R -- UC_PLAN_ARCH
R -- UC_STAGE

M -- UC_DETAIL
M -- UC_VALIDER

RRH -- UC_KPI
RRH -- UC_PIPELINE
RRH -- UC_ONBOARD

UC_SCORER -- IA
UC_COMPOSITE -- IA
UC_EVALREPONSE -- IA
UC_WHISPER -- IA
UC_ARCH_EVAL -- IA
UC_CONVERT -- IA
UC_EMAIL -- IA

UC_DEPOSER ..> UC_SCORER      : <<include>>
UC_TECH ..> UC_EVALREPONSE    : <<include>>
UC_TECH ..> UC_COMPOSITE      : <<include>>
UC_ARCH ..> UC_WHISPER         : <<include>>
UC_ARCH ..> UC_ARCH_EVAL       : <<include>>

UC_DEPOSER <.. UC_CONVERT     : <<extend>>
UC_VALIDER <.. UC_DECISION    : <<extend>>
UC_PLAN_TECH <.. UC_REPLAN    : <<extend>>
UC_PLAN_ARCH <.. UC_REPLAN    : <<extend>>
UC_STAGE <.. UC_EMAIL         : <<extend>>

note bottom of UC_AUTH
  Tous les espaces authentifiés
  incluent « S'authentifier »
end note

@enduml
